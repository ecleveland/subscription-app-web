# MongoDB
MONGODB_URI=mongodb://mongo:27017/subscriptions

# Auth
AUTH_USERNAME=admin
AUTH_PASSWORD_HASH=       # Generate with: node -e "require('bcryptjs').hash('yourpassword',10).then(console.log)"
JWT_SECRET=               # Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_EXPIRES_IN=24h

# CORS
FRONTEND_URL=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001/api
