# Backend environment variables. Copy to `.env` and fill in real values.
# `.env` is gitignored — never commit secrets.

# --- Core ---
PORT=3001
# Local dev uses the docker-compose Mongo (bound to 127.0.0.1). In production,
# use an authenticated, network-restricted Atlas URI (see docs/railway-deployment.md).
MONGODB_URI=mongodb://localhost:27017/subscriptions

# --- Auth ---
# JWT signing secret — REQUIRED, must be >= 32 chars (openssl rand -hex 32).
JWT_SECRET=replace-with-a-strong-secret-at-least-32-characters
JWT_EXPIRES_IN=15m
# Optional pepper for HMAC-ing refresh/reset tokens at rest. Defaults to JWT_SECRET.
# TOKEN_PEPPER=
# Optional seeded admin (bcrypt hash of the password). Leave blank to skip seeding.
# AUTH_PASSWORD_HASH=

# --- CORS / frontend ---
FRONTEND_URL=http://localhost:3000

# --- Mail ---
# `console` (default off-prod) logs the reset/invite link for local testing.
# `smtp` sends real email and is the default + required driver in production.
MAIL_DRIVER=console
# SMTP settings (required when MAIL_DRIVER=smtp):
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM=Subscription App <no-reply@subscription-app.local>

# --- Logging ---
LOG_LEVEL=info
LOG_PRETTY=true
